# ---------------------------------------------------------------------------
# Redis (Upstash)
# Set EITHER (a) KV_REST_API_URL + KV_REST_API_TOKEN (auto-populated when
# you link the dunamis-studios-kv integration in Vercel) OR (b) REDIS_URL
# against a self-hosted Redis. The app prefers (a) when both are set.
# ---------------------------------------------------------------------------
REDIS_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ---------------------------------------------------------------------------
# Session signing — generate with: openssl rand -base64 48
# Must be at least 32 chars. Rotating invalidates all active sessions.
# ---------------------------------------------------------------------------
JWT_SECRET=

# ---------------------------------------------------------------------------
# KB rating IP-hash salt. SHA-256 over the IP address uses this salt so
# per-article vote dedup can't be reversed to the source IP.
# Generate once: openssl rand -hex 32
# Rotating resets every article's dedup state (already-voted counter).
# ---------------------------------------------------------------------------
KB_RATING_SALT=

# ---------------------------------------------------------------------------
# Resend transactional email
# ---------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@dunamisstudios.net

# ---------------------------------------------------------------------------
# Stripe — provision both a webhook secret AND a server-side secret key.
# STRIPE_MODE selects live vs test keyset (defaults to test).
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is safe to expose client-side.
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MODE=test
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Property Pulse one-time license price ID. $49 per portal. Read by
# getPropertyPulseLicensePriceId() to build Stripe Checkout sessions
# from /api/stripe/create-one-time-checkout. The Stripe webhook endpoint
# must subscribe to `checkout.session.completed` for purchase ingestion
# (charge.refunded is already subscribed for the refund path).
STRIPE_PRICE_PROPERTY_PULSE_LICENSE=

# ---------------------------------------------------------------------------
# Base URL for email links, cookie scope, etc.
# ---------------------------------------------------------------------------
APP_URL=https://dunamisstudios.net

# ---------------------------------------------------------------------------
# HMAC-SHA256 secret for verifying the install-handoff state token that
# Property Pulse / Debrief pass when a user installs the app in HubSpot.
# The product server signs the token with this same secret; any mismatch
# fails every claim with "signature mismatch" and blocks new installs from
# linking their account here.
#
# Generate once: openssl rand -hex 32
# Set the SAME value in this project's Vercel env AND in each product
# repo's Vercel env (CLAIM_STATE_SECRET). Rotating this invalidates all
# in-flight claim links (15-minute TTL anyway, so low blast radius), but
# must be done across all three projects in lockstep.
# ---------------------------------------------------------------------------
CLAIM_STATE_SECRET=

# ---------------------------------------------------------------------------
# HubSpot private-app access token for the Dunamis Studios CRM portal
# (portal 20867488). Used server-side to send custom event occurrences to
# /events/v3/send and to upsert contact properties for account activity,
# install/uninstall, billing, and terms acceptance tracking.
#
# Create at HubSpot → Settings → Integrations → Private Apps. Required
# scopes:
#   - crm.objects.contacts.read
#   - crm.objects.contacts.write
#   - crm.schemas.contacts.read
#   - behavioral_events.event_definitions.read_write (read/define events)
#   - analytics.behavioral_events.send (send event occurrences via
#     POST /events/v3/send — NOT covered by the event_definitions scope;
#     missing this returns HTTP 403 on every send)
#
# NEVER prefix with NEXT_PUBLIC_ — the token is secret. src/lib/hubspot/*
# modules import "server-only" to enforce this at build time.
# ---------------------------------------------------------------------------
HUBSPOT_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Admin access — comma-separated list of account emails that can access
# /admin routes. Case-insensitive. Example: alice@example.com,bob@example.com
# ---------------------------------------------------------------------------
ADMIN_EMAILS=

NODE_ENV=production
