# Upstash Redis (auto-populated when you link dunamis-studios-kv in Vercel)
REDIS_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Session signing — generate with: openssl rand -base64 48
JWT_SECRET=

# Resend transactional email
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@dunamisstudios.net

# Base URL for email links, cookie scope, etc
APP_URL=https://dunamisstudios.net

NODE_ENV=production
