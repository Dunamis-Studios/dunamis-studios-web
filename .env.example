# Upstash Redis (auto-populated when you link dunamis-studios-kv in Vercel)
REDIS_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Session signing — generate with: openssl rand -base64 48
JWT_SECRET=

# Resend transactional email
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@dunamisstudios.net

# Base URL for email links, cookie scope, etc
APP_URL=https://dunamisstudios.net

# HMAC-SHA256 secret for verifying the install-handoff state token
# that Debrief passes when a user installs Debrief in HubSpot. The
# Debrief server (separate repo) signs the token with this same
# secret; any mismatch fails every claim with "signature mismatch"
# and blocks new installs from linking their account here.
#
# Generate once: openssl rand -hex 32
# Set the SAME value in both this project's and the Debrief repo's
# Vercel env (CLAIM_STATE_SECRET). Rotating this invalidates all
# in-flight claim links (15-minute TTL anyway, so low blast radius),
# but must be done on both sides in lockstep.
CLAIM_STATE_SECRET=

NODE_ENV=production
